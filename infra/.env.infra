# Infraestructura - variables configurables
# Copia este archivo a .env en la raiz del proyecto o usa -f infra/.env.infra

# Imagenes Docker
PYTHON_IMAGE=python:3.9-slim
NODE_IMAGE=node:20-alpine
NGINX_IMAGE=nginx:alpine

# Usuario contenedor
APP_UID=1000
APP_GID=1000

# Puertos
FRONTEND_PORT=5173
NGINX_PORT=80

# Nombres de contenedores
BACKEND_CONTAINER_NAME=london_crime_app
FRONTEND_CONTAINER_NAME=datagestor-frontend

# Nginx
NGINX_GZIP_MIN_LENGTH=256
