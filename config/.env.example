# Supabase (público - solo lectura)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# VITE_SUPABASE_TABLE_NAME=london_crime_aggregated

# GCP (opcional - solo si ejecutas pipeline con datos reales)
# GOOGLE_APPLICATION_CREDENTIALS=ruta/a/tu/credentials.json
# GCP_PROJECT_ID=london-crime-491323
# BIGQUERY_TABLE=bigquery-public-data.london_crime.crime_by_lsoa
# BIGQUERY_ROW_LIMIT=100000

# Backend (opcional - solo si cargas a Supabase)
SUPABASE_DB_URL=postgresql://user:pass@host:port/database

# Configuración del pipeline
# DATA_DIR=data
# LOG_LEVEL=INFO
# LOG_FILENAME=pipeline.log
# SUPABASE_TABLE_NAME=london_crime_aggregated
# DB_IF_EXISTS=replace
# DB_CHUNKSIZE=1000
# EXPORT_COMPRESSION=snappy
# EXPORT_FORMATS=parquet,csv

# Nombres de archivos del pipeline
# RAW_FILENAME=london_crime_raw
# VALIDATED_FILENAME=london_crime_validated
# PROCESSED_FILENAME=london_crime_processed
# VALIDATION_REPORT_FILENAME=validation_report

# Validación
# VALIDATION_MIN_YEAR=2000
# VALIDATION_IQR_MULTIPLIER=1.5
# VALIDATION_ZSCORE_THRESHOLD=3

# Datos de muestra (modo demo)
# SAMPLE_N_ROWS=150
# SAMPLE_RANDOM_SEED=42
# SAMPLE_POISSON_MEAN=15
VITE_ML_API_URL=http://localhost:8000
VITE_SUPABASE_TABLE_NAME=london_crime_aggregated
VITE_SUPABASE_PAGE_SIZE=1000
LOG_JSON=true
METRICS_SCHEMA_VERSION=1.0
ML_RANDOM_STATE=42
ML_LOGREG_MAX_ITER=1000
ML_RF_N_ESTIMATORS=80
ML_RF_MIN_SAMPLES_LEAF=3
LOAD_DEMO_TO_SUPABASE=false
